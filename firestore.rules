
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user belongs to a specific organization
    function isUserInOrg(orgId) {
      return request.auth.token.organizationId == orgId;
    }

    // Helper function to check for user roles
    function isRole(role) {
      return request.auth.token.role == role;
    }
    
    function isSuperAdmin() {
      return isRole('super_admin');
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    // Users can read their own profile. Admins can read profiles in their org. Super admins can read all.
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || (isRole('admin') && isUserInOrg(resource.data.organizationId)));
      allow write: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      // Allow creation during signup process
      allow create: if true; 
    }

    // Organizations can be read by any authenticated user within that org. Only Super Admins can manage them.
    match /organizations/{orgId} {
      allow read: if isSignedIn() && (isSuperAdmin() || isUserInOrg(orgId));
      allow list, write: if isSuperAdmin();

      // Subcollections within an organization
      match /{subcollection}/{docId} {
        allow read, write: if isSuperAdmin() || (isRole('admin') && isUserInOrg(orgId));
      }
      
      // Rules for Collaborators on specific subcollections
      match /evaluations/{evalId} {
         allow read: if isSignedIn() && isUserInOrg(orgId); // Admins and collaborators can read evaluations in their org
         allow write: if isRole('admin') && isUserInOrg(orgId); // Only admins can write/create evaluations
      }

      match /challenges/{challengeId} {
        allow read: if isSignedIn() && isUserInOrg(orgId);
        allow write: if isRole('admin') && isUserInOrg(orgId);
      }
      
      match /challengeParticipations/{participationId} {
        allow read: if isSignedIn() && isUserInOrg(orgId);
        // Collaborators can create their own participation, or update it if they are the owner
        allow create: if isSignedIn() && isUserInOrg(orgId) && request.resource.data.employeeId == request.auth.uid;
        allow update: if (isRole('admin') && isUserInOrg(orgId)) || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      }
    }
    
    // Plans can be read by any authenticated user (useful for displaying plan info)
    // Only super admins can create/edit/delete plans
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    
    // Award History can be read by users of that organization.
    // Only super admins and admins of that org can create them (via backend/CF)
    match /awardHistory/{historyId} {
      allow read: if isSignedIn() && isUserInOrg(resource.data.organizationId);
      allow write: if isSuperAdmin() || (isRole('admin') && isUserInOrg(resource.data.organizationId));
      allow create: if isSuperAdmin() || (isRole('admin') && isUserInOrg(request.resource.data.organizationId));
    }
  }
}
