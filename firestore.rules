rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function isUserInOrg(orgId) {
      return isSignedIn() && request.auth.token.organizationId == orgId;
    }

    function isOwnRecord(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Regras para a coleção 'users'
    match /users/{userId} {
      // Permite que um usuário leia seu próprio documento para obter role/orgId
      // Permite que super_admin leia qualquer perfil
      allow read: if isOwnRecord(userId) || isSuperAdmin();
      
      // Apenas super_admin pode criar/escrever/deletar diretamente.
      // Outras modificações são feitas via Cloud Functions.
      allow write, delete: if isSuperAdmin();
    }

    // Regras para a coleção 'organizations'
    match /organizations/{orgId} {
      // Super admins podem fazer tudo.
      // Admins/Colaboradores da organização podem ler os detalhes da organização.
      allow read: if isSuperAdmin() || isUserInOrg(orgId);
      allow write, delete: if isSuperAdmin();

      // Regras para todas as subcoleções (tasks, challenges, evaluations, etc.)
      match /{subcollection}/{docId} {
        // Admins/Colaboradores da organização podem ler os dados.
        allow read: if isSuperAdmin() || isUserInOrg(orgId);

        // Apenas Super Admins e Admins da organização podem criar/atualizar/deletar dados
        // (Ex: criar uma tarefa, avaliar um desafio).
        allow write, delete: if isSuperAdmin() || (isUserInOrg(orgId) && request.auth.token.role == 'admin');
      }
    }

    // Regras para coleções de nível raiz (ex: plans, awards)
    match /plans/{planId} {
      // Qualquer usuário autenticado pode ler os planos. Apenas Super Admin pode modificar.
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /awards/{awardId} {
      // Qualquer usuário autenticado pode ler as premiações. Apenas Super Admin pode modificar.
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /awardHistory/{historyId} {
      // Qualquer usuário autenticado pode ler o histórico. Apenas Super Admin pode criar/modificar.
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
