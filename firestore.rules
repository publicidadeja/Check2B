
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isCollaborator() {
      return isSignedIn() && request.auth.token.role == 'collaborator';
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isUserInOrg(organizationId) {
        return request.auth.token.organizationId == organizationId;
    }

    // Organizations: Super Admins can manage all. Admins can read their own.
    match /organizations/{organizationId} {
      allow read: if isSuperAdmin() || (isAdmin() && isUserInOrg(organizationId));
      allow write: if isSuperAdmin(); // Only Super Admins can create/update/delete orgs

      // Subcollections within organizations
      
      // Tasks: Admins of the org can manage tasks. Collaborators can read.
      match /tasks/{taskId} {
        allow read: if (isAdmin() || isCollaborator()) && isUserInOrg(organizationId);
        allow write: if isAdmin() && isUserInOrg(organizationId);
      }
      
      // Evaluations: Admins can manage. Collaborators can read their own.
      match /evaluations/{evaluationId} {
        allow read: if (isAdmin() && isUserInOrg(organizationId)) || (isCollaborator() && isUserInOrg(organizationId) && resource.data.employeeId == request.auth.uid);
        allow write: if isAdmin() && isUserInOrg(organizationId);
      }

      // Departments & Roles: Managed by Admins within their organization. Collaborators can read.
      match /departments/{departmentId} {
         allow read: if (isAdmin() || isCollaborator()) && isUserInOrg(organizationId);
         allow write: if isAdmin() && isUserInOrg(organizationId);
      }
      match /roles/{roleId} {
        allow read: if (isAdmin() || isCollaborator()) && isUserInOrg(organizationId);
        allow write: if isAdmin() && isUserInOrg(organizationId);
      }
      
      // Challenges & Participations
      match /challenges/{challengeId} {
        allow read: if (isAdmin() || isCollaborator()) && isUserInOrg(organizationId);
        allow write: if isAdmin() && isUserInOrg(organizationId);
      }
      match /challengeParticipations/{participationId} {
        allow read: if (isAdmin() && isUserInOrg(organizationId)) || (isCollaborator() && isUserInOrg(organizationId) && resource.data.employeeId == request.auth.uid);
        // Collaborators can create/update their own submissions, Admins can evaluate
        allow write: if (isCollaborator() && isUserInOrg(organizationId) && request.resource.data.employeeId == request.auth.uid) || (isAdmin() && isUserInOrg(organizationId));
      }

      // Challenge Management (Settings)
      match /challengeManagement/{docId} {
          allow read: if isAdmin() && isUserInOrg(organizationId);
          allow write: if isAdmin() && isUserInOrg(organizationId);
      }
      
      // App Settings
      match /appSettings/{docId} {
          allow read: if isAdmin() && isUserInOrg(organizationId);
          allow write: if isAdmin() && isUserInOrg(organizationId);
      }

       // Ranking Management
      match /rankingManagement/{docId} {
          allow read: if isAdmin() && isUserInOrg(organizationId);
          allow write: if isAdmin() && isUserInOrg(organizationId);
      }
    }

    // Users: Can only read/update their own profile. Admins can read users in their org. Super Admins can manage all.
    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin() || (isAdmin() && isUserInOrg(resource.data.organizationId));
      allow update: if isOwner(userId) || isSuperAdmin();
      // Create/delete handled by Cloud Functions
      allow create, delete: if false; 
      
      // User settings subcollection
      match /settings/{settingId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Plans: Managed by Super Admin only. Readable by Admins.
    match /plans/{planId} {
      allow read: if isSuperAdmin() || isAdmin();
      allow write: if isSuperAdmin();
    }
    
    // Award History: Readable by Super Admin and users of the specific organization. Writable only by Super Admin (via Cloud Function).
    match /awardHistory/{historyId} {
      allow read: if isSuperAdmin() || (isSignedIn() && isUserInOrg(resource.data.organizationId));
      allow write: if isSuperAdmin(); // Writes should come from a trusted server/function
    }
    
    // Awards: Managed by Super Admin only. Readable by Admins.
    match /awards/{awardId} {
        allow read: if isSuperAdmin() || isAdmin();
        allow write: if isSuperAdmin();
    }
  }
}
