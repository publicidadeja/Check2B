rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Collection Rules
    match /users/{userId} {
      // Helper function to check if the user is the owner of the document
      function isOwner() {
        return request.auth.uid == userId;
      }

      // Helper function to check which fields are being updated
      function allowedUpdateFields() {
        // Users can update their name, photo, phone, and FCM tokens.
        // They CANNOT update their own role, organizationId, or status.
        return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['name', 'photoUrl', 'phone', 'fcmTokens', 'updatedAt']);
      }

      // Allow read access for the owner of the document.
      // Allow update access only for the owner and only for specific, safe fields.
      allow read, update: if isOwner() && allowedUpdateFields();
      allow create: if request.auth.uid != null; // Allow creation for any authenticated user
    }

    // Organizations and their subcollections
    match /organizations/{organizationId} {
      // Helper function to check if the user belongs to this organization
      function isMember() {
        return request.auth.token.organizationId == organizationId;
      }
      
      // Allow any authenticated user (admins, collaborators of any org) to read organization details
      // This is generally safe as it contains public info like name and plan.
      allow read: if request.auth != null;

      // Rules for all subcollections within an organization
      match /{subcollection}/{docId} {
        // Members of the organization can read any document in any subcollection.
        allow read: if isMember();
        
        // Write access should be more specific per subcollection if needed,
        // but for now, we grant it to members as well.
        // This can be tightened later (e.g., only admins can write to 'tasks').
        allow write: if isMember();
      }
    }
    
    // Plan data is public and can be read by any authenticated user
    match /plans/{planId} {
      allow read: if request.auth != null;
    }
    
    // Award history is tied to an organization, readable by its members
    match /awardHistory/{historyId} {
        allow read: if request.auth.token.organizationId == resource.data.organizationId;
    }

    // Notifications are private to each user (read/write only by the user)
    // Note: Notifications are in Realtime Database in this project, these rules are placeholders if moved to Firestore.
    match /userNotifications/{userId}/{notificationId} {
       allow read, write: if request.auth.uid == userId;
    }
  }
}
