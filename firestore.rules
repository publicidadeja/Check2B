rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'super_admin';
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isCollaborator() {
      return isSignedIn() && request.auth.token.role == 'collaborator';
    }

    function isUserInOrg(organizationId) {
      return request.auth.token.organizationId == organizationId;
    }

    // Organizations can be read by any authenticated user, but only written by super admins.
    match /organizations/{organizationId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();

      // All subcollections within an organization follow these rules:
      match /{subcollection}/{document=**} {
        // Admins of the organization can do anything.
        // Collaborators of the organization can only read.
        allow read: if isSignedIn() && isUserInOrg(organizationId);
        allow write: if isAdmin() && isUserInOrg(organizationId);
      }
    }

    // Users can only read their own profile data.
    // Admins can read all user profiles within their organization.
    // Super admins can read all user profiles.
    match /users/{userId} {
      allow read: if (isSignedIn() && request.auth.uid == userId) ||
                     (isAdmin() && isUserInOrg(get(/databases/$(database)/documents/users/$(userId)).data.organizationId)) ||
                     isSuperAdmin();
      allow update: if isSignedIn() && request.auth.uid == userId; // Allow users to update their own profile
      allow create, delete: if isSuperAdmin() || isAdmin(); // Only admins/superAdmins can create/delete user profiles directly
    }

    // Plans can be read by any authenticated user, but only written by super admins
    match /plans/{planId} {
        allow read: if isSignedIn();
        allow write: if isSuperAdmin();
    }
    
    // Award history is readable by authenticated users in the org, writable by admins/superAdmins
    match /awardHistory/{historyId} {
        allow read: if isSignedIn() && isUserInOrg(resource.data.organizationId);
        allow write: if isSuperAdmin() || (isAdmin() && isUserInOrg(resource.data.organizationId));
    }
  }
}
