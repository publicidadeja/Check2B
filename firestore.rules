
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to get the user's role from their custom claims.
    function getRole() {
      return request.auth.token.role;
    }

    // Helper function to check if the user has a specific role.
    function hasRole(role) {
      return isAuthenticated() && getRole() == role;
    }
    
    // Helper function to get the user's organizationId from claims.
    function getOrgId() {
        return request.auth.token.organizationId;
    }
    
    // Helper function to check if the requesting user belongs to the resource's organization.
    function isMemberOf(orgId) {
        return isAuthenticated() && getOrgId() == orgId;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Any authenticated user can create their own profile (usually done via Cloud Function).
      allow create: if isAuthenticated();
      
      // A user can read and update their own profile data.
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
      
      // Admins and Super Admins can read/write any user's profile.
      allow read, write: if hasRole('admin') || hasRole('super_admin');
    }

    // Rules for organizations and their subcollections
    match /organizations/{orgId}/{document=**} {
      // Admins of the organization and Super Admins can read/write any document within the organization.
      allow read, write: if hasRole('super_admin') || isMemberOf(orgId);
      
      // Collaborators can only read documents within their own organization.
      allow read: if hasRole('collaborator') && isMemberOf(orgId);
    }
    
    // Rules for top-level collections accessible mostly by Super Admins
    match /plans/{planId} {
        allow read: if isAuthenticated(); // All authenticated users can read plans
        allow write: if hasRole('super_admin'); // Only super admins can modify plans
    }

    match /awardHistory/{historyId} {
        allow read: if isAuthenticated(); // All authenticated users can see award history
        allow write: if hasRole('super_admin') || hasRole('admin'); // Admins can confirm winners
    }

    match /awards/{awardId} {
        allow read: if isAuthenticated(); // All can read available awards
        allow write: if hasRole('super_admin'); // Only super admins can manage awards
    }
  }
}
