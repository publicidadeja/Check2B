
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user belongs to a specific organization.
    // It checks the custom claims on the user's auth token.
    function isMemberOf(orgId) {
      return request.auth != null && request.auth.token.organizationId == orgId;
    }
    
    // Helper function to check if the user has a specific role.
    function hasRole(role) {
      return request.auth != null && request.auth.token.role == role;
    }

    // Organizations can be read by any authenticated user to list them (if needed),
    // but only super admins can create, update, or delete them.
    match /organizations/{orgId} {
      allow read: if request.auth != null;
      allow write: if hasRole('super_admin');

      // Rules for all subcollections within an organization
      match /{subcollection}/{docId} {
        // Admins and collaborators can read/write data within their own organization.
        allow read, write: if isMemberOf(orgId);
      }
    }

    // Users collection rules
    match /users/{userId} {
      // A user can read their own profile.
      allow read: if request.auth.uid == userId;
      
      // A user can update their own profile (e.g., name, photo).
      // Admins of the same org or super admins can also update user profiles.
      allow update: if request.auth.uid == userId || 
                       (hasRole('admin') && isMemberOf(resource.data.organizationId)) ||
                       hasRole('super_admin');
                       
      // Only admins or super admins can create users (delegated to Cloud Functions).
      allow create: if hasRole('admin') || hasRole('super_admin');
      
      // Users cannot be deleted directly via client SDK for security reasons.
      // This is handled by a Cloud Function.
      allow delete: if false;

      // Settings subcollection for a user (e.g., notifications)
      match /settings/{settingId} {
          allow read, write: if request.auth.uid == userId;
      }
    }
    
    // Award History is readable by any authenticated user (so collaborators can see winners).
    // Writing is handled by a Cloud Function or a trusted admin process.
    match /awardHistory/{historyId} {
        allow read: if request.auth != null;
        allow write: if hasRole('admin') || hasRole('super_admin');
    }

    // Plans collection can be read by any authenticated user.
    // Writing is restricted to super admins.
    match /plans/{planId} {
        allow read: if request.auth != null;
        allow write: if hasRole('super_admin');
    }
    
    // Awards can be read by any authenticated user.
    // Writing is restricted to super admins.
    match /awards/{awardId} {
        allow read: if request.auth != null;
        allow write: if hasRole('super_admin');
    }
  }
}
