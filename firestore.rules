
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to get a user's role from their custom claims
    function getRole() {
      return request.auth.token.role;
    }

    // Helper function to get a user's organizationId from their custom claims
    function getOrgId() {
      return request.auth.token.organizationId;
    }
    
    // Helper function to check if the user is a Super Admin
    function isSuperAdmin() {
      return isAuthenticated() && getRole() == 'super_admin';
    }
    
    // Helper function to check if the user is an Admin of a specific organization
    function isAdmin(orgId) {
      return isAuthenticated() && getRole() == 'admin' && getOrgId() == orgId;
    }

    // Helper function to check if the user is a Collaborator of a specific organization
    function isCollaborator(orgId) {
       return isAuthenticated() && getRole() == 'collaborator' && getOrgId() == orgId;
    }

    // Super Admins can read/write anything (global access)
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Allow a user to read/update their own profile
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
      // Allow admins to read profiles within their own organization
      allow read: if isAdmin(resource.data.organizationId);
      // Create/Delete are typically handled by Cloud Functions for security
      allow create, delete: if false; 
    }

    // Rules for organizations and their subcollections
    match /organizations/{orgId}/{document=**} {
      // Admins and Collaborators can read documents within their own organization
      allow read: if isAdmin(orgId) || isCollaborator(orgId);
      // Admins can write documents within their own organization
      allow write: if isAdmin(orgId);
    }
    
    // Rules for top-level collections accessible by Super Admins or specific logic
    match /plans/{planId} {
        // Plans are public to read for selection, but only Super Admins can change them.
        allow read: if isAuthenticated();
        allow write: if isSuperAdmin();
    }

    match /awardHistory/{historyId} {
      // History is specific to an organization, check the orgId field in the document
      allow read: if isAuthenticated() && getOrgId() == resource.data.organizationId;
      allow write: if isSuperAdmin() || isAdmin(resource.data.organizationId);
    }
    
    match /awards/{awardId} {
       allow read: if isAuthenticated();
       allow write: if isSuperAdmin();
    }
  }
}
