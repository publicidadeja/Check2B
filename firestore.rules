rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read and update their own profile information.
    // They cannot change their role or organizationId through this rule.
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
      // Explicitly deny create/delete on their own profile doc for safety.
      allow create, delete: if false;
    }

    // Rules for organizations and their subcollections
    // An authenticated user can read any document inside their own organization.
    // This is necessary for pages like Dashboard, Challenges, Ranking, etc.
    match /organizations/{orgId}/{document=**} {
      allow read: if request.auth.token.organizationId == orgId;

      // Write access is more granular and typically handled by Cloud Functions,
      // but admins can have broader write access for management tasks.
      // Collaborators have very limited write access, defined in specific subcollections if needed.
      allow write: if request.auth.token.role == 'admin' && request.auth.token.organizationId == orgId;
    }

    // Rules for challenge participations
    // A user can create their own participation document.
    match /organizations/{orgId}/challengeParticipations/{participationId} {
        allow create: if request.auth.uid == request.resource.data.employeeId;
        allow update: if request.auth.uid == resource.data.employeeId; // Allow user to update their own submission
    }

    // Super Admins have read/write access to everything for management purposes.
    // This rule is checked if other rules deny access.
    match /{path=**}/documents {
      allow read, write: if request.auth.token.role == 'super_admin';
    }
  }
}
